# event-service configuration.
# Connection vars MUST match backendV2 in any given environment — both services
# share the same Postgres/TimescaleDB and Redis.

# HTTP port Flussonic posts event_sink to (point Flussonic's event_sink URL here)
PORT=4100

# Shared data stores
DATABASE_URL=postgres://user:pass@localhost:5432/streamforge
REDIS_URL=redis://localhost:6379/0

# Flussonic API (bandwidth/session enrichment)
FLUSSONIC_API_URL=https://flussonic.example.com
FLUSSONIC_API_TOKEN=your-token

# Must equal backendV2's FLUSSONIC_EVENT_SINK_SIGN_KEY. Empty disables verification.
FLUSSONIC_EVENT_SINK_SIGN_KEY=

# Use the SAME .mmdb file backendV2 uses (parity for the `cities` Redis key).
GEOIP_CITY_DB_PATH=/GeoIPLite2/GeoLite2-City/GeoLite2-City.mmdb

# Tuning (optional)
DB_POOL_SIZE=20
WORKER_CONCURRENCY=16
SUMMARY_DEBOUNCE_MS=1500
FLUSSONIC_TIMEOUT_MS=4000
FLUSSONIC_MAX_INFLIGHT=8

# Set true ONLY for a clean single-instance boot. Leave false during shadow-mode
# and cutover so live analytics keys are not wiped.
CLEAR_ANALYTICS_ON_START=false

NODE_ENV=production
